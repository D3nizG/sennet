# Server
PORT=3001
NODE_ENV=development

# Database
# Use a direct PostgreSQL connection locally.
# In production, DATABASE_URL is often the pooled URL and DIRECT_URL is the direct/non-pooled URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sennet?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/sennet?schema=public"

# JWT
JWT_SECRET=replace-with-at-least-32-random-characters

# CORS
CLIENT_URL=http://localhost:5173
